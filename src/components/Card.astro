---
const { artists } = Astro.props;
---

<a href={`/Artist?id=${artists.id}`} class="card">
  <img src={artists.image_url} alt={artists.name} />
  <h2>{artists.name}</h2>
</a>

<style>
.card {
  display: block;
  text-decoration: none;
  color: black;
  max-width: 200px;
  padding-bottom: 100px;
}

.card img {
  width: 100%;
  aspect-ratio: 1;
  object-fit: cover;
  box-shadow:1px 1px 25px 2px rgba(0, 0, 0, 0.3) ;
  
}

h2{
  padding-top: 10px;
  text-align: center;
}
</style>