---
import Layout from "../layouts/Layout.astro";

---

<Layout titel="Artist">
  <article>
    <h1 id="name">Loading...</h1>
    <img id="image" />
    <p id="description"></p>
  </article>
<script>
  const params = new URLSearchParams(window.location.search);
  const id = params.get("id");

  const url = `${import.meta.env.PUBLIC_SUPABASE_URL}/rest/v1/artists?id=eq.${id}&select=*`;

  fetch(url, {
    headers: {
      apikey: import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY,
    },
  })
    .then(res => res.json())
    .then(([artists]) => {
      document.querySelector("#name").textContent = artists.name;
      document.querySelector("#image").src = artists.image_url;
      document.querySelector("#description").textContent = artists.description;
    });
    console.log("ID fra URL:", id);
    
</script>
</Layout>