---
import "../css/global.css";
import Footer from "../components/Footer.astro";
import Card from "../components/Card.astro";

const url = `${import.meta.env.PUBLIC_SUPABASE_URL}/rest/v1/artists?select=*&limit=3`;

const data = await fetch(url, {
  headers: {
    apikey: import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY,
  },
}).then((res) => res.json());
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>HØSTEN</title>
  </head>

  <body>
    <h1>28-29 August</h1>
    <div class="video-wrapper">
      <video controls>
        <source src="public/video/HØMØ 26 story 5_1.mov" />
      </video>
    </div>
    <div class="sidebar">
      <video src="public/video/sideBar2.0.mp4"></video>
    </div>

    <section class="grid-1-3">
        {data.map((artist) => (
    <Card artists={artist} />
  ))}
     <!-- <img
        class="artistscard"src="public/imgs/snuggleCard.webp" alt="billedet til artister"
      />

      <img
        class="artistscard"src="public/imgs/snuggleCard.webp" alt="billedet til artister"
      /> -->
    </section>

    

    <style>
      .video-wrapper {
        display: flex;
        justify-content: center; /* center horizontally */
        margin: 90px 0; /* space above & below */
        width: 100%;
      }
      /* .artistscard {
        width: 40%;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
      } */
      
      .grid-1-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        padding: 20px;
      }
    </style>
  </body>
</html>
