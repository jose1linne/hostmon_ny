---
import "../css/global.css";
import Footer from "../components/Footer.astro";
import Card from "../components/Card.astro";
import Navbar from "../components/Navigationbar.astro";
---

<header>
  <Navbar />
</header>

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>HØSTEN</title>
  </head>

  <body>
    <h1>28-29 August</h1>

    <div class="video-wrapper">
      <video controls>
        <source src="public/video/Homo26story5_1.mov" type="video/mp4" />
      </video>
    </div>

    <section class="grid-1-3">
      <div>
        <img
          class="artistscard"
          src="public/imgs/MajkeVossCard.webp"
          alt="programcards"
        />
        <p class="">MAJKE VOSS</p>
      </div>

      <div>
        <img
          class="artistscard"
          src="public/imgs/SchoolOfXCard.webp"
          alt="programcards"
        />
        <p>MAJKE VOSS</p>
      </div>

      <div>
        <img
          class="artistscard"
          src="public/imgs/BokoYoutCard.webp"
          alt="programcards"
        />
        <p>MAJKE VOSS</p>
      </div>
    </section>
  </body>

  <style>
    .video-wrapper {
      display: flex;
      justify-content: center; /* centers horizontally */
    }

    .video-wrapper video {
      width: 500%; /* 👈 makes it smaller */
      max-width: 1700px; /* stops it getting too big */
    }
    .grid-1-3 {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      margin-top: 150px;
    }
    .artistscard {
      gap: 30px;
      max-width: 500px;
      margin: 30px auto;
    }
  </style>
</html>
