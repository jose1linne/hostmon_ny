---
import "../css/global.css";
import Footer from "../components/Footer.astro";
import Card from "../components/Card.astro";
import Navbar from "../components/Navigationbar.astro";
import Layout from "../layouts/Layout.astro";

const url = `${import.meta.env.PUBLIC_SUPABASE_URL}/rest/v1/artists?select=*&limit=3`;

const data = await fetch(url, {
  headers: {
    apikey: import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY,
  },
}).then((res) => res.json());
---

<Layout title="forside">
  <h1>28-29 August</h1>

  <div class="video-wrapper">
    <video controls>
      <source src="public/video/Homo26story5_1.mov" type="video/mp4" />
    </video>
  </div>

  <section class="grid-1-3">
    {data.map((artist) => <Card artists={artist} />)}
  </section>
</Layout>
<style>
  .video-wrapper {
    display: flex;
    justify-content: center; /* centers horizontally */
  }

  .video-wrapper video {
    width: 500%; /* 👈 makes it smaller */
    max-width: 1700px; /* stops it getting too big */
  }
  .grid-1-3 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    margin-top: 150px;
  }
</style>
